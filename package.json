{
  "name": "latteart",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source, local-first, provider-agnostic AI image studio with real non-destructive layers.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c yellow,cyan \"vp run @latteart/server#dev\" \"vp run @latteart/web#dev\"",
    "dev:web": "vp run @latteart/web#dev",
    "dev:server": "vp run @latteart/server#dev",
    "build": "vp run -r build",
    "check": "vp check",
    "test": "vp run -r test",
    "ready": "vp check && vp run -r build"
  },
  "devDependencies": {
    "concurrently": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.9.0"
}
